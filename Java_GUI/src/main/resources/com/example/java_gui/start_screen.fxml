<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.java_gui.Start_Screen">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: #d3d3d3; -fx-border-color: #a9a9a9;">
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
            <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Aplikacja Okienkowa" />
            <ImageView fitHeight="100.0" preserveRatio="true">
                <image>
                    <Image url="@images/logotypy-pwr.png" />
                </image>
            </ImageView>
        </HBox>
    </top>

    <left>
        <VBox alignment="CENTER" spacing="10.0">
            <padding><Insets bottom="20.0" left="20.0" right="10.0" top="20.0" /></padding>
            <Button fx:id="Import" onAction="#wybierzPlik" text="Importuj Obraz" />
            <ImageView fx:id="org" fitWidth="500" fitHeight="600.0" preserveRatio="true" />
        </VBox>
    </left>

    <center>
        <VBox alignment="CENTER" spacing="10.0">
            <ComboBox fx:id="operacje" promptText="Wybierz operację">
                <items>
                    <FXCollections fx:factory="observableArrayList">
                        <String fx:value="Negatyw"/>
                        <String fx:value="Progowanie"/>
                        <String fx:value="Konturowanie"/>
                    </FXCollections>
                </items>
            </ComboBox>
            <Button fx:id="wykonaj_przycisk" text="Wykonaj" onAction="#Wykonaj" disable="true"/>
            <Button fx:id="skaluj_przycisk" text="Skaluj" onAction="#skalujObraz" disable="true"/>
            <HBox alignment="CENTER" spacing="10">
                <Button fx:id="obrotLewo_przycisk" onAction="#obrocLewo" text="↶" disable="true"/>
                <Button fx:id="obrotPrawo_przycisk" onAction="#obrocPrawo" text="↷" disable="true"/>
            </HBox>
        </VBox>
    </center>

    <right>
        <VBox alignment="CENTER">
            <padding><Insets bottom="20.0" left="10.0" right="20.0" top="20.0" /></padding>
            <Button fx:id="zapisz_przycisk" text="Zapisz" onAction="#zapisz" disable="true"/>
            <ImageView fx:id="mod" fitWidth="500.0" fitHeight="600.0" preserveRatio="true" />
        </VBox>
    </right>

    <bottom>
        <HBox style="-fx-background-color: #d3d3d3; -fx-border-color: #a9a9a9; -fx-border-width: 1 0 0 0;">
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
            <Label text="Mikołaj Nowak 280082" />
        </HBox>
    </bottom>

</BorderPane>